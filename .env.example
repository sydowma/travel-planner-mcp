# API Keys (可选，有免费替代方案)

# ===== 航班搜索 API =====
# Kiwi Tequila API (推荐) - https://tequila.kiwi.com/portal/login
# 免费使用，数据来自Skyscanner
KIWI_API_KEY=your_kiwi_api_key

# Amadeus API (备选) - https://developers.amadeus.com/
# AMADEUS_CLIENT_ID=your_amadeus_client_id
# AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# SerpAPI (备选) - https://serpapi.com/ (100次/月免费)
# SERP_API_KEY=your_serp_api_key

# ===== 天气 API =====
# OpenWeatherMap API (https://openweathermap.org/api) - 免费版可用
OPENWEATHER_API_KEY=your_openweather_api_key

# ===== 汇率 API =====
# Exchange Rate API (https://exchangerate-api.com/) - 免费版可用
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
